# Appwrite Configuration
# See scripts/google-oauth-setup-checklist.md for setup instructions

# Public variables (exposed to client)
PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
# Optional: Canonical URL for OAuth redirects (production only, if behind reverse proxy)
# PUBLIC_APP_URL=https://yourdomain.com

# Private variables (server-side only, NEVER expose to client)
APPWRITE_PROJECT_ID=your-project-id-here
APPWRITE_API_KEY=your-api-key-here

# Google Maps API (if used)
# PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Sentry (error tracking)
# SENTRY_DSN=your-sentry-dsn-here
